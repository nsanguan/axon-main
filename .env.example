# =============================================================================
# Axon — Environment Configuration Template
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# --- MCP Server Endpoints (all separate projects — Axon connects as MCP client only) ---
# mcp-oracle-ebs — separate project
AXON_MCP_ORACLE_EBS__URL=http://localhost:8001/mcp
# mcp-sap — separate project
AXON_MCP_SAP__URL=http://localhost:8002/mcp
# mcp-odoo — separate project
AXON_MCP_ODOO__URL=http://localhost:8003/mcp
# mcp-policy-server (RAG — SOPs, compliance, policies) — separate project on port 8021
AXON_MCP_EXTERNAL_RAG__URL=http://0.0.0.0:8021/mcp
# mcp-postgresql — separate project
AXON_MCP_POSTGRESQL__URL=http://localhost:8005/mcp

# mcp-excalidraw — visual diagram MCP server
AXON_MCP_EXCALIDRAW__URL=http://localhost:8089/mcp
AXON_MCP_EXCALIDRAW__ENABLED=false

# --- MCP Authentication ---
AXON_MCP_ORACLE_EBS__API_KEY=change-me
AXON_MCP_SAP__API_KEY=change-me
AXON_MCP_EXTERNAL_RAG__API_KEY=change-me

# --- Database ---
AXON_DATABASE__URL=postgresql+asyncpg://axon:axon@localhost:5432/axon

# --- Redis ---
AXON_REDIS__URL=redis://localhost:6379/0

# --- LLM Configuration ---
AXON_LLM__MODEL=claude-3-5-sonnet-20241022
AXON_LLM__API_KEY=change-me
AXON_LLM__MAX_TOKENS=4096

# --- Observability ---
AXON_LOGFIRE_TOKEN=
AXON_LOG_LEVEL=INFO

# --- Agent Defaults ---
AXON_AGENT_DEFAULTS__MAX_RETRIES=3
AXON_AGENT_DEFAULTS__TIMEOUT_SECONDS=120
AXON_AGENT_DEFAULTS__NEGOTIATION_ROUNDS=5

# --- Security ---
AXON_SECRET_KEY=change-me-to-random-64-characters-minimum
